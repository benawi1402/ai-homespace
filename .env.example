# ─── Weather (OpenWeatherMap) ───────────────────────────────────────────────
WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_CITY=Amsterdam
WEATHER_UNITS=metric
# Cache TTL in seconds
WEATHER_CACHE_TTL=600

# ─── Mail account 1 (IMAP) ───────────────────────────────────────────────────
MAIL_HOST=imap.example.com
MAIL_PORT=993
MAIL_USER=user@example.com
MAIL_PASSWORD=your_mail_password
MAIL_TLS=true
MAIL_MAILBOX=INBOX
MAIL_NAME=Personal
# Cache TTL in seconds
MAIL_CACHE_TTL=120

# ─── Mail account 2 (IMAP) — optional second account ─────────────────────────
MAIL2_HOST=
MAIL2_PORT=993
MAIL2_USER=
MAIL2_PASSWORD=
MAIL2_TLS=true
MAIL2_MAILBOX=INBOX
MAIL2_NAME=Work
MAIL2_CACHE_TTL=120

# ─── Home Control (Home Assistant local REST API) ────────────────────────────
# Point this at your Home Assistant instance on the local network.
# When running in Docker, use the host IP or mDNS name, NOT localhost.
HASS_URL=http://192.168.1.100:8123
HASS_TOKEN=your_long_lived_access_token
# Cache TTL in seconds
HASS_CACHE_TTL=30

# ─── News (RSS + optional OpenAI ranking) ────────────────────────────────────
# Optional: override or extend the default curated RSS feeds.
# Format: comma-separated "url|Display Name" pairs.
# Example: NEWS_FEED_URLS=https://news.ycombinator.com/rss|Hacker News,https://www.rockpapershotgun.com/feed|RPS
NEWS_FEED_URLS=
# Cache TTL in seconds (default 30 minutes)
NEWS_CACHE_TTL=1800

# Optional: OpenAI API key enables AI-powered relevance ranking.
# Without it the panel works with keyword-based scoring.
# Model defaults to gpt-4o-mini (cheap + fast — ranking a list of headlines
# costs fractions of a cent per cache refresh).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
DATA_DIR=/app/data
